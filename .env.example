# Database
DATABASE_URL="file:./dev.db"

# LLM Provider — set ONE of these
# For Claude (Anthropic)
ANTHROPIC_API_KEY=""

# For OpenAI
OPENAI_API_KEY=""

# Active provider: "anthropic" | "openai" | "mock"
LLM_PROVIDER="anthropic"

# Default model per provider
ANTHROPIC_MODEL="claude-sonnet-4-6"
OPENAI_MODEL="gpt-4o"
